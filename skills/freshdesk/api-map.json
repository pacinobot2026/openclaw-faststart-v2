{
  "api_name": "Freshdesk API",
  "api_version": "v2",
  "docs_root": "https://developers.freshdesk.com/api/",
  "base_url_template": "https://{FRESHDESK_DOMAIN}/api/v2",
  "auth": {
    "type": "basic",
    "formats": [
      "API key as username + 'X' as dummy password",
      "Base64 encode 'API_KEY:X' for Authorization header"
    ],
    "header_format": "Authorization: Basic {base64(API_KEY:X)}",
    "secret_handling": "never log raw credentials"
  },
  "rate_limits": {
    "trial": 50,
    "growth": 200,
    "pro": 400,
    "enterprise": 700,
    "unit": "requests per minute",
    "headers": {
      "total": "X-RateLimit-Total",
      "remaining": "X-RateLimit-Remaining",
      "used": "X-RateLimit-Used-CurrentRequest",
      "retry_after": "Retry-After"
    }
  },
  "pagination": {
    "type": "page-based",
    "params": {
      "page": "Page number (starts at 1)",
      "per_page": "Results per page (max 100, default 30)"
    },
    "link_header": true
  },
  "content_type": "application/json",
  "endpoints": [
    {
      "group": "Tickets",
      "name": "Create Ticket",
      "method": "POST",
      "path": "/tickets",
      "purpose": "Create a new support ticket",
      "required_fields": ["email OR requester_id OR phone OR twitter_id"],
      "optional_fields": ["subject", "description", "status", "priority", "source", "type", "responder_id", "group_id", "product_id", "company_id", "tags", "cc_emails", "due_by", "fr_due_by", "custom_fields", "attachments", "parent_id", "related_ticket_ids"],
      "pagination": null
    },
    {
      "group": "Tickets",
      "name": "View Ticket",
      "method": "GET",
      "path": "/tickets/{id}",
      "purpose": "Retrieve details of a specific ticket",
      "path_params": ["id"],
      "query_params": [{"name": "include", "values": ["conversations", "requester", "company", "stats", "sla_policy"]}]
    },
    {
      "group": "Tickets",
      "name": "List All Tickets",
      "method": "GET",
      "path": "/tickets",
      "purpose": "List tickets with optional filters",
      "query_params": [
        {"name": "filter", "values": ["new_and_my_open", "watching", "spam", "deleted"]},
        {"name": "requester_id", "type": "integer"},
        {"name": "email", "type": "string"},
        {"name": "company_id", "type": "integer"},
        {"name": "updated_since", "type": "datetime"},
        {"name": "order_by", "values": ["created_at", "due_by", "updated_at", "status"]},
        {"name": "order_type", "values": ["asc", "desc"]},
        {"name": "include", "values": ["requester", "stats", "description"]}
      ],
      "pagination": "page, per_page"
    },
    {
      "group": "Tickets",
      "name": "Filter Tickets",
      "method": "GET",
      "path": "/search/tickets",
      "purpose": "Search tickets using query syntax",
      "query_params": [{"name": "query", "required": true, "example": "\"status:2 AND priority:4\""}],
      "pagination": "page (max 10 pages, 30 per page)"
    },
    {
      "group": "Tickets",
      "name": "Update Ticket",
      "method": "PUT",
      "path": "/tickets/{id}",
      "purpose": "Update an existing ticket",
      "path_params": ["id"]
    },
    {
      "group": "Tickets",
      "name": "Bulk Update Tickets",
      "method": "PUT",
      "path": "/tickets/bulk_update",
      "purpose": "Update multiple tickets at once",
      "required_fields": ["ids", "properties"]
    },
    {
